{
    "name": "zephyrisle/fof-formatting-pro",
    "description": "Enhanced Flarum formatting extension with audio support, Chinese platforms (NetEase Cloud Music, Bilibili), and custom audio CSS",
    "keywords": [
        "flarum",
        "formatting",
        "audio",
        "netease",
        "bilibili",
        "chinese"
    ],
    "type": "flarum-extension",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "flarum/core": "^2.0.0"
    },
    "support": {
        "issues": "https://github.com/Zephyr-Isle/fof-formatting-pro/issues",
        "source": "https://github.com/Zephyr-Isle/fof-formatting-pro"
    },
    "authors": [
        {
            "name": "zephyrisle",
            "email": "zephyrisle@example.com",
            "homepage": "https://github.com/Zephyr-Isle"
        }
    ],
    "autoload": {
        "psr-4": {
            "Zephyrisle\\FormattingPro\\": "src/"
        }
    },
    "extra": {
        "branch-alias": {
            "2.x": "2.x-dev"
        },
        "flarum-extension": {
            "title": "FoF Formatting Pro",
            "category": "feature",
            "id": "zephyrisle-fof-formatting-pro",
            "icon": {
                "name": "fas fa-music",
                "backgroundColor": "#ff6b6b",
                "color": "#fff"
            }
        },
        "flarum-cli": {
            "modules": {
                "githubActions": true
            }
        },
        "database-support": ["mysql", "sqlite", "pgsql"]
    },
    "require-dev": {
        "flarum/phpstan": "^2.0.0"
    },
    "scripts": {
        "analyse:phpstan": "phpstan analyse",
        "clear-cache:phpstan": "phpstan clear-result-cache",
        "build:js": "cd js && npm install && npm run build"
    },
    "scripts-descriptions": {
        "analyse:phpstan": "Run static analysis",
        "build:js": "Build JavaScript assets"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
